<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- 
      IIS Configuration cho HTML2Image API
      Chạy Python qua httpPlatformHandler
      
      HƯỚNG DẪN CẤU HÌNH:
      1. Thay đổi processPath: đường dẫn đến python.exe trong virtual environment
      2. Thay đổi arguments: đường dẫn đến webhook.py (có thể dùng đường dẫn tuyệt đối hoặc tương đối)
      3. Thay đổi stdoutLogFile: đường dẫn nơi lưu log file
      4. Thay đổi PYTHONPATH: đường dẫn đến thư mục dự án
    -->
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <httpPlatform
      processPath="C:\path\to\your\venv\Scripts\python.exe"
      arguments="C:\path\to\your\project\webhook.py"
      stdoutLogEnabled="true"
      stdoutLogFile="C:\path\to\your\project\webhook.log"
      startupTimeLimit="180"
      processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="PYTHONPATH" value="C:\path\to\your\project" />
        <environmentVariable name="HTTP_PLATFORM_PORT" value="%HTTP_PLATFORM_PORT%" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>